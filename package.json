{
  "name": "lynx-doctor-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter lynx-doctor test",
    "check": "pnpm build && pnpm typecheck && pnpm test",
    "dev": "pnpm --filter lynx-doctor dev",
    "docs:dev": "pnpm --filter @lynx-doctor/website dev",
    "docs:build": "pnpm --filter @lynx-doctor/website build",
    "docs:preview": "pnpm --filter @lynx-doctor/website preview"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
